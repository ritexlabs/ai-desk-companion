# ─────────────────────────────────────────────────────────────────────────────
# AI Desk Companion — Desktop (Vite/React) environment variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is git-ignored.
# All variables must be prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the orchestrator backend.
# Change this if you run the orchestrator on a different host or port.
# Default (when not set): http://localhost:8787
# VITE_BACKEND_URL=http://localhost:8787
