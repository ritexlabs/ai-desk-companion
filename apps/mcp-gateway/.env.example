# ── MCP Gateway ──────────────────────────────────────────────────────────────
# Port the gateway listens on (must match GATEWAY_URL in orchestrator .env)
GATEWAY_PORT=8788
GATEWAY_HOST=0.0.0.0

# ── INDmoney MCP (Phase 2) ────────────────────────────────────────────────────
# Tokens are injected per-session by the orchestrator; no static creds needed.
# INDMONEY_MCP_ENDPOINT=https://mcp.indmoney.com/mcp

# ── GitHub MCP binary (Phase 2) ───────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...

# ── Google MCP (Phase 3a) ─────────────────────────────────────────────────────
# Tokens are injected per-session by the orchestrator; no static creds needed.

# ── Weather API (Phase 3b) ────────────────────────────────────────────────────
# WEATHER_API_KEY=
# WEATHER_PROVIDER=openweathermap   # openweathermap | weatherapi | open_meteo

# ── News API (Phase 3b) ───────────────────────────────────────────────────────
# NEWS_API_KEY=
# NEWS_DEFAULT_COUNTRY=in
