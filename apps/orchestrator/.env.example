# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Robo Wake-Up Orchestrator
ENV=development
LOG_LEVEL=INFO

# ── Voice Providers ──────────────────────────────────────────────────────────
# TTS_PROVIDER: browser | openai | elevenlabs
TTS_PROVIDER=browser

# STT_PROVIDER: browser | openai
STT_PROVIDER=browser

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Required when TTS_PROVIDER=openai or STT_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# OpenAI TTS options (only relevant when TTS_PROVIDER=openai)
# Voice: alloy | echo | fable | onyx | nova | shimmer   (default: nova)
# OPENAI_TTS_VOICE=nova
# Model: tts-1 | tts-1-hd   (default: tts-1, tts-1-hd is slower but higher quality)
# OPENAI_TTS_MODEL=tts-1

# ── ElevenLabs ───────────────────────────────────────────────────────────────
# Required when TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=Rachel

# ── Stock Market Agent ───────────────────────────────────────────────────────
# Uses Yahoo Finance (yfinance) — free, no API key required.
# default_market: IN (NSE Indian stocks/indices) | US (NYSE/NASDAQ)
# STOCK_DEFAULT_MARKET=IN

# ── Wake Word Detection (Phase 5, optional) ──────────────────────────────────
# Requires: pip install sounddevice openwakeword numpy
# macOS:    brew install portaudio
# WAKE_WORD_ENABLED=false
# WAKE_WORD_MODEL=hey_jarvis   # hey_jarvis | alexa | hey_mycroft | hey_rhasspy
# WAKE_WORD_SENSITIVITY=0.5    # 0.1 (loose) – 0.9 (strict)
