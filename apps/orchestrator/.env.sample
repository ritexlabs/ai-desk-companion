# ─────────────────────────────────────────────────────────────────────────────
# AI Desk Companion — Orchestrator environment variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Robo AI Orchestrator
ENV=development
LOG_LEVEL=INFO

# Phrase Robo listens for to wake up (customise to avoid false triggers)
WAKE_PHRASE=Robo

# How long (seconds) an idle agent is kept warm before it is recycled
AGENT_IDLE_TTL_SECONDS=600

# Comma-separated origins allowed to connect to the orchestrator WebSocket.
# Add your Tauri app origin if you change the default port.
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,tauri://localhost


# ── LLM — used for intent routing and general AI responses ───────────────────
# Provider: openai | anthropic | gemini | ollama
LLM_PROVIDER=openai

# API key for the chosen provider.
# For OpenAI:    sk-...
# For Anthropic: sk-ant-...
# For Gemini:    AIza...
# Not needed for Ollama (local model).
# OPENAI_API_KEY=sk-...

# Model override — leave blank to use the provider's default recommended model.
# Examples: gpt-4o | claude-opus-4-8 | gemini-2.0-flash | llama3.2
# LLM_MODEL=

# Ollama base URL (only needed when LLM_PROVIDER=ollama)
# LLM_BASE_URL=http://localhost:11434


# ── Voice — TTS (Text-to-Speech) ─────────────────────────────────────────────
# Provider: browser | openai | elevenlabs
TTS_PROVIDER=browser

# ── OpenAI TTS (only when TTS_PROVIDER=openai) ───────────────────────────────
# Uses the same OPENAI_API_KEY above.
# Voice: alloy | echo | fable | onyx | nova | shimmer   (default: nova)
OPENAI_TTS_VOICE=nova
# Model: tts-1 | tts-1-hd   (tts-1-hd is slower but higher quality)
OPENAI_TTS_MODEL=tts-1

# ── ElevenLabs TTS (only when TTS_PROVIDER=elevenlabs) ───────────────────────
# ELEVENLABS_API_KEY=
# Voice name or ID from your ElevenLabs account
# ELEVENLABS_VOICE_ID=Rachel


# ── Voice — STT (Speech-to-Text) ─────────────────────────────────────────────
# Provider: browser | openai
# openai uses Whisper — requires OPENAI_API_KEY above.
STT_PROVIDER=browser


# ── Wake Word Detection (optional, server-side) ───────────────────────────────
# Requires: pip install sounddevice openwakeword numpy
# macOS:    brew install portaudio
WAKE_WORD_ENABLED=false
# Model: hey_jarvis | alexa | hey_mycroft | hey_rhasspy
WAKE_WORD_MODEL=hey_jarvis
# Sensitivity: 0.1 (very loose, many false positives) – 0.9 (very strict)
WAKE_WORD_SENSITIVITY=0.5


# ── Weather Agent ─────────────────────────────────────────────────────────────
# Provider: openweathermap | weatherapi
# Leave API key blank to use the free Open-Meteo fallback (no key needed).
WEATHER_PROVIDER=openweathermap
# WEATHER_API_KEY=
WEATHER_DEFAULT_CITY=Bengaluru


# ── GitHub Agent ──────────────────────────────────────────────────────────────
# Personal Access Token — generate at github.com/settings/tokens
# Scopes needed: repo, read:user, notifications
# GITHUB_TOKEN=ghp_...


# ── Google Agents (Calendar + Gmail) ─────────────────────────────────────────
# Prefer setting these via the UI (Settings → Agents → Google).
# These .env values are used as server-side fallbacks only.
# Access tokens are short-lived — use the UI OAuth flow for automatic refresh.
# GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# GOOGLE_ACCESS_TOKEN=
# GOOGLE_REFRESH_TOKEN=


# ── Stock Market Agent ────────────────────────────────────────────────────────
# Powered by Yahoo Finance (yfinance) — free, no API key required.
# Market: IN (NSE Indian stocks/indices) | US (NYSE/NASDAQ)
STOCK_DEFAULT_MARKET=IN


# ── News Agent (GNews) ────────────────────────────────────────────────────────
# Free developer key from gnews.io (100 req/day).
# Leave blank — agent will return a "no key" message until configured via UI.
# NEWS_API_KEY=
# ISO 2-letter country code for default top headlines
NEWS_DEFAULT_COUNTRY=in


# ── Smart Home Agent (Home Assistant) ────────────────────────────────────────
# URL of your Home Assistant instance (local network or Nabu Casa cloud URL).
MYHOME_MCP_ENDPOINT=http://homeassistant.local:8123
# Long-lived access token — HA Profile → Long-lived access tokens → Create Token
# MYHOME_MCP_TOKEN=eyJ...


# ── WhatsApp Agent (Meta Cloud API) ──────────────────────────────────────────
# Phone Number ID — Meta Developer Console → WhatsApp → API Setup
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Permanent system user token (preferred) or temporary test token
# WHATSAPP_ACCESS_TOKEN=EAAxxxxx...
# Custom string you set in Meta Developer Console → Webhooks → Verify Token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=robo-whatsapp-verify
# App Secret — Meta Developer Console → App Settings → Basic → App Secret
# When set, every incoming webhook POST is validated via X-Hub-Signature-256.
# Strongly recommended when using a public tunnel (cloudflare).
# WHATSAPP_APP_SECRET=
# Contacts list: one "Name: +E164number" entry per line
# WHATSAPP_CONTACTS=Mom: +919876543210\nJohn: +14155552671


# ── Tunnel (webhook callback URL for WhatsApp) ────────────────────────────────
# Your domain for Cloudflare Named Tunnel (optional).
# If set, the callback URL is https://whatsapp.<CLOUDFLARE_DOMAIN>/webhook/whatsapp
# and the domain is pre-filled in the Settings panel.
# Requires: cloudflared tunnel create whatsapp
#           See .cloudflared/whatsapp-config.example.yml for full setup.
# CLOUDFLARE_DOMAIN=yourdomain.com
